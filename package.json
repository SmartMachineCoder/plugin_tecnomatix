{
  "name": "plugin-tecnomatix",
  "version": "1.0.0",
  "description": "Insights Hub Monitor Plugin — bridges IH asset/time-series data to Tecnomatix Plant Simulation",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production && cp Staticfile dist/plugin-tecnomatix/browser/Staticfile",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/platform-browser-dynamic": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@mindsphere/oi-plugin-sdk": "file:./mindsphere-oi-plugin-sdk-2.0.22.tgz",
    "@siemens/ix": "^1.6.0",
    "@siemens/ix-angular": "^1.6.0",
    "mqtt": "^5.0.0",
    "rxjs": "^6.6.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.2",
    "typescript": "^5.9.0"
  }
}
